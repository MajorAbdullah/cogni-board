# Copy to backend/.env and fill in. NEVER commit the real .env.

# --- Database (PostgreSQL) ---
# Local dev: a docker Postgres, or your Railway Postgres public URL.
# Railway: this is auto-injected by the Postgres plugin.
DATABASE_URL=postgresql://postgres:password@localhost:5432/agentic

# --- User-supplied DB connections (SSRF guard) ---
# /api/db/test and /api/db/tables accept an arbitrary connection string from
# an unauthenticated onboarding flow. By default, connections to
# private/loopback/link-local hosts are blocked. Set to "true" ONLY for local
# dev where the user's target Postgres genuinely lives on localhost/a private
# network — leave "false" (or unset) in any deployed environment.
ALLOW_PRIVATE_DB_HOSTS=false

# --- Saved data-source credential encryption ---
# Required for the Datasets tab's "save & switch sources without re-entering
# credentials" feature. Generate once and keep it stable — rotating it makes
# every previously saved connection undecryptable.
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_SOURCE_ENCRYPTION_KEY=

# --- Redis cache ---
# Local: docker Redis. Railway: the Redis plugin's REDIS_URL.
# Optional — the app falls back to an in-memory cache if unset/unreachable.
REDIS_URL=redis://localhost:6379/0

# --- LLM providers (at least ONE required) ---
# Which provider to try first: "fireworks" (AMD-hosted, e.g. Gemma) or "openrouter".
# The other acts as an automatic fallback.
LLM_PROVIDER=fireworks

# Fireworks AI (primary) — AMD-hardware-hosted models. Get a key at fireworks.ai.
# Model IDs are account-scoped: accounts/fireworks/models/<slug>. Override the
# model vars to match the model the hackathon announces (the serverless catalog
# rotates, so a retired slug will 404 and the app falls back to OpenRouter).
FIREWORKS_API_KEY=fw-...
FIREWORKS_MODEL_FAST=accounts/fireworks/models/gemma-3-12b-it
FIREWORKS_MODEL_STRONG=accounts/fireworks/models/gemma-3-12b-it

# OpenRouter (fallback) — optional once Fireworks is configured.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL_FAST=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_STRONG=anthropic/claude-3.5-sonnet

# --- Inflectiv (data / RAG) ---
INFLECTIV_BASE=https://app.inflectiv.ai/api/platform
# Optional convenience fallback key. The real flow captures a per-user key at onboarding.
INFLECTIV_API_KEY=

# --- Retrieval tuning (optional) ---
DEFAULT_TOP_K=20
DEFAULT_SCORE_THRESHOLD=0.2

# --- CORS (optional; same-origin in prod so not needed) ---
CORS_ORIGINS=*
